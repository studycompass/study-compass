---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <!-- Homepage -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
    <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Tool Pages -->
  <url><loc>{{ site.url }}{{ site.baseurl }}/timer.html</loc><priority>0.9</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/flashcards.html</loc><priority>0.9</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/calculator.html</loc><priority>0.9</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/quiz.html</loc><priority>0.9</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/planner.html</loc><priority>0.9</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/essay.html</loc><priority>0.9</priority><changefreq>monthly</changefreq></url>

  <!-- Blog Index -->
  <url><loc>{{ site.url }}{{ site.baseurl }}/blog.html</loc><priority>0.8</priority><changefreq>weekly</changefreq></url>

  <!-- Static Blog Articles (legacy) -->
  <url><loc>{{ site.url }}{{ site.baseurl }}/pomodoro.html</loc><priority>0.7</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/active-recall.html</loc><priority>0.7</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/essay-outline.html</loc><priority>0.7</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/weekly-planning.html</loc><priority>0.7</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/gpa.html</loc><priority>0.7</priority><changefreq>monthly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/student-reset.html</loc><priority>0.7</priority><changefreq>monthly</changefreq></url>

  <!-- Legal & Contact -->
  <url><loc>{{ site.url }}{{ site.baseurl }}/privacy.html</loc><priority>0.3</priority><changefreq>yearly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/terms.html</loc><priority>0.3</priority><changefreq>yearly</changefreq></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/contact.html</loc><priority>0.3</priority><changefreq>yearly</changefreq></url>

  <!-- CMS-Published Blog Posts (auto-generated by Jekyll) -->
  {% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date: "%Y-%m-%d" }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endfor %}

</urlset>
